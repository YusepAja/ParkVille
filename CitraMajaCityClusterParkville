<!DOCTYPE html>

<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RT Parkville</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body{margin:0;font-family:Poppins;background:#f1f5f9}
.wrapper{display:flex;height:100vh}

/* SIDEBAR */
.sidebar{
  width:230px;background:white;padding:10px;
  box-shadow:0 10px 30px rgba(0,0,0,0.1)
}
.sidebar h2{text-align:center;color:#2563eb}
.sidebar button{
  width:100%;padding:10px;margin:5px 0;
  border:none;border-radius:10px;cursor:pointer;
  background:#f1f5f9
}
.sidebar button:hover{background:#dbeafe}

/* CONTENT */
.content{flex:1;padding:20px;overflow:auto}
.card{
  background:white;padding:15px;border-radius:12px;
  margin-bottom:15px;box-shadow:0 5px 15px rgba(0,0,0,0.1)
}
.tab{display:none}
.active{display:block}
.bad{color:red;font-weight:bold}

/* HUJAN */
.leaf{
  position:fixed;top:-50px;pointer-events:none;
  animation:fall linear forwards;z-index:999
}
@keyframes fall{
  0%{transform:translateY(-50px);opacity:0}
  10%{opacity:1}
  100%{transform:translateY(110vh);opacity:0}
}

/* ===== DARK MODE ===== */
body.dark .card{
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(34,197,94,0.4);

  box-shadow: 
    0 0 20px rgba(34,197,94,0.4),
    0 0 60px rgba(34,197,94,0.2);
}

body.dark{
  background: radial-gradient(circle at top, #022c22, #000);
}
body.dark{
  background: linear-gradient(135deg,#022c22,#064e3b,#022c22);
  color:#e2e8f0;
}

/* glow neon */
body.dark .card{
  box-shadow: 0 0 20px rgba(34,197,94,0.4),
              0 0 40px rgba(34,197,94,0.2);
}

body.dark .menu button{
  box-shadow: 0 0 15px rgba(34,197,94,0.5);
}
/* HEADER */
.header{
  display:flex;
  align-items:center;
  gap:20px;
  padding:20px;

  background: linear-gradient(135deg,#dbeafe,#e0f2fe);
  border-bottom:3px solid #2563eb;
}

.logo{
  width:70px;
  height:70px;
  object-fit:contain;
  border-radius:12px;
  background:white;
  padding:5px;
}

.title{
  flex:1;
  text-align:center;
}

.title h1{
  margin:0;
  font-size:22px;
  color:#1e3a8a;
}

.title h2{
  margin:4px 0;
  font-size:16px;
  color:#2563eb;
}

.title p{
  margin:2px 0;
  font-size:13px;
  color:#334155;
}
</style>

</head>

<body>

<div class="wrapper">

<div class="sidebar">
  <h2>Cluster Parkville</h2>
  <button onclick="openTab('dashboard')">🏠 Dashboard</button>
  <button onclick="openTab('warga')">👥 Warga</button>
  <button onclick="openTab('iklan')">⭐ Lapak</button>
  <button onclick="openTab('keuangan')">💰 Keuangan</button>
  <button onclick="openTab('tunggakan')">🔴 Tunggakan</button>
  <button onclick="openTab('pengumuman')">🔔 Info</button>
  <button onclick="openTab('Media')">📸 Kegiatan</button>
</div>

<div class="content">

<div class="header">
  <img src="Logo.png" class="logo">

  <div class="title">
    <h1>Citra Maja City Cluster Parkville</h1>
    <h2>RT 005 / RW 004</h2>
    <p>Desa Curugbadak Kecamatan Maja</p>
    <p>Sekretariat : Jl Parkville 10 Blok A11/31</p>
  </div>
  <button class="toggle" onclick="toggleMode()">🌙</button>
</div>

<!-- DASHBOARD -->

<div id="dashboard" class="tab active">
  <div class="card">
    <h3>Summary</h3>
    <p>Warga: <span id="wargaCount"></span></p>
     <p>💰 Iuran: <b id="iuran"></b></p>
      <p style="font-size:12px;color:#64748b">
        Per Orang: Rp 15.000<br>
        (Kematian Rp5.000 • Satpam Rp5.000 • Kas Rp5.000)
      </p>
    <p>Sampah: <span id="sampah"></span></p>
    <p>Saldo: <b id="saldo"></b></p>
  </div>

  <div class="card">
    <h3>Grafik Bulanan</h3>
    <canvas id="chart"></canvas>
  </div>

  <div class="card">
    <h3>Kontak</h3>
    <div id="kontak"></div>
  </div>
</div>

<div id="warga" class="tab"><div class="card"><table id="tbWarga"></table></div></div>
<div id="iklan" class="tab"><div class="card"><div id="listIklan"></div></div></div>
<div id="keuangan" class="tab"><div class="card"><table id="tbKeu"></table></div></div>
<div id="tunggakan" class="tab"><div class="card"><table id="tbTunggakan"></table></div></div>

<div id="pengumuman" class="tab"><div id="listPengumuman"></div>
</div>
<div id="Media" class="tab"><div class="card"><div id="gallery"></div></div></div>

</div>
</div>

<script>
/* ===== URL (7 DATA) ===== */
const URL_W="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=941193884";
const URL_B="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=595238022";
const URL_K="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=1027936274";
const URL_S="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=1872595743";
const URL_PROFILE="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=422911818";
const URL_PENGUMUMAN = "https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/gviz/tq?tqx=out:json&gid=941802545"; URL_SALDO="https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/export?format=csv&gid=508041483";

const URL_MEDIA = "https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/gviz/tq?tqx=out:json&gid=784856855";
const URL_LAPAK =
"https://docs.google.com/spreadsheets/d/1KeenLY16qqCOwqn1CgryqHWEe7kSOjW6YmHzsZLy7SE/gviz/tq?tqx=out:json&gid=1556678723";

let W=[],B=[],K=[],S=[],P=[],PG=[],SA=[];

/* ===== CSV ===== */
/* ===== CSV FIX (ANTI KOMA) ===== */
function csv(text){
  let rows = text.trim().split("\n");
  let headers = rows[0].split(",");

  return rows.slice(1).map(row=>{
    // regex biar koma di dalam teks tidak pecah
    let cols = row.match(/(".*?"|[^",]+)(?=\s*,|\s*$)/g);

    let obj = {};
    headers.forEach((h,i)=>{
      let val = (cols[i] || "")
        .replace(/^"|"$/g, "") // hapus tanda kutip
        .trim();

      obj[h.trim().toLowerCase()] = val;
    });

    return obj;
  });
}

function num(x){
  return parseFloat((x||"0").replace(/\./g,"").replace(",","."))||0;
}

function rp(x){
  return "Rp "+x.toLocaleString("id-ID");
}
/* ===== HUJAN DAUN ===== */
function hujanDaun(){
  setInterval(()=>{
    let leaf = document.createElement("div");
    leaf.className = "leaf";

    const daun = ["🍃","🍂","🌿","💧","❄️","🔥","👍","🥶","👻","🦷","💧","💦","🫧"];
    leaf.innerText = daun[Math.floor(Math.random()*daun.length)];

    leaf.style.left = Math.random() * window.innerWidth + "px";

    // speed beda2
    leaf.style.animationDuration = (4 + Math.random()*6) + "s, 3s";

    leaf.style.fontSize = (15 + Math.random()*25) + "px";

    document.body.appendChild(leaf);

    setTimeout(()=>leaf.remove(),10000);
  }, 250);
}
/* ===== LOAD ===== */
async function load(){
  let [w,b,k,s,p,pg,sa]=await Promise.all([
    fetch(URL_W).then(r=>r.text()),
    fetch(URL_B).then(r=>r.text()),
    fetch(URL_K).then(r=>r.text()),
    fetch(URL_S).then(r=>r.text()),
    fetch(URL_PROFILE).then(r=>r.text()),
    fetch(URL_PENGUMUMAN).then(r=>r.text()),
    fetch(URL_SALDO).then(r=>r.text())
  ]);

  W=csv(w); B=csv(b); K=csv(k); S=csv(s);
  P=csv(p); PG=csv(pg); SA=csv(sa);

  render();
}

/* ===== RENDER ===== */
function render(){

  let iuran=B.reduce((a,b)=>a+num(b.jumlah),0);
  let sampah=S.reduce((a,b)=>a+num(b.jumlah),0);
  let keluar=K.reduce((a,b)=>a+num(b.jumlah),0);
  let saldoAwal=SA.length?num(SA[0].saldo):0;
  let saldo=saldoAwal+iuran+sampah-keluar;

  document.getElementById("wargaCount").innerText=W.length;
  document.getElementById("iuran").innerText=rp(iuran);
  document.getElementById("sampah").innerText=rp(sampah);
  document.getElementById("saldo").innerText=rp(saldo);

  warga();
  keuangan();
  tunggakan();
  kontak();
  pengumuman();
  grafik();
  hujanDaun();
  loadIklan();
}

/* ===== GRAFIK ===== */
function grafik(){
  let map={};

  B.forEach(x=>{
    let t=new Date(x.tanggal);
    let key=t.getFullYear()+"-"+(t.getMonth()+1);
    if(!map[key]) map[key]={i:0,s:0};
    map[key].i+=num(x.jumlah);
  });

  S.forEach(x=>{
    let t=new Date(x.tanggal);
    let key=t.getFullYear()+"-"+(t.getMonth()+1);
    if(!map[key]) map[key]={i:0,s:0};
    map[key].s+=num(x.jumlah);
  });

  let labels=Object.keys(map);
  let iuran=labels.map(k=>map[k].i);
  let sampah=labels.map(k=>map[k].s);

  new Chart(document.getElementById("chart"),{
    type:'pie',
    data:{
      labels:labels,
      datasets:[
        {label:'Iuran',data:iuran,borderWidth:3},
        {label:'Sampah',data:sampah,borderWidth:3}
      ]
    }
  });
}

/* ===== LAINNYA ===== */
function warga(){
  let tb=document.getElementById("tbWarga");
  tb.innerHTML="<tr><th>Nama</th><th>Rumah</th></tr>";
  W.forEach(w=>tb.innerHTML+=`<tr><td>${w.nama}</td><td>${w.rumah}</td></tr>`);
}

function keuangan(){
  let tb=document.getElementById("tbKeu");
  tb.innerHTML="<tr><th>Tanggal</th><th>Jumlah</th></tr>";
  B.forEach(x=>tb.innerHTML+=`<tr><td>${x.tanggal}</td><td>${rp(num(x.jumlah))}</td></tr>`);
}

function tunggakan(){
  let tb=document.getElementById("tbTunggakan");
  tb.innerHTML="<tr><th>Nama</th></tr>";
  W.forEach(w=>{
    let bayar=B.some(x=>x.warga_id==w.id);
    if(!bayar) tb.innerHTML+=`<tr><td class="bad">${w.nama}</td></tr>`;
  });
}

function kontak(){
  let div=document.getElementById("kontak");
  div.innerHTML="";
  P.forEach(x=>{
    div.innerHTML+=`<p>${x.jabatan} - ${x.nama} 
    <a href="https://wa.me/${x.wa}" target="_blank">📞</a></p>`;
  });
}

function pengumuman(){
  let div=document.getElementById("listPengumuman");
  div.innerHTML="";
  PG.forEach(x=>{
    div.innerHTML+=`<div class="card"><h3>${x.judul}</h3><p>${x.isi}</p></div>`;
  });
}
function convertDrive(link){
  if(!link) return "";
  let match = link.match(/[-\w]{25,}/);
  return match 
    ? `https://drive.google.com/thumbnail?id=${match[0]}&sz=w1000`
    : "";
}
/* ===== LOAD IKLAN ===== */
function loadIklan(){

  fetch(URL_LAPAK)
  .then(r=>r.text())
  .then(data=>{

    let match = data.match(/google\.visualization\.Query\.setResponse\((.*)\);/s);
    if(!match){
      document.getElementById("listIklan").innerHTML = "Data tidak terbaca";
      return;
    }

    let json = JSON.parse(match[1]);
    let rows = json.table.rows || [];

    let html = "";

    rows.reverse().forEach(r=>{

      let penjual = r.c[0]?.v || "";
      let judul   = r.c[1]?.v || "";
      let desc    = r.c[2]?.v || "";
      let harga   = r.c[3]?.v || 0;
      let kontak  = r.c[4]?.v || "";
      let img     = convertDrive(r.c[5]?.v || "");

      html += `
      <div style="display:inline-block;width:200px;margin:10px;
      background:white;padding:10px;border-radius:12px">

        <img src="${img}" style="width:100%;height:140px;object-fit:cover;border-radius:10px"
        onerror="this.src='https://via.placeholder.com/200x140'">

        <b>${judul}</b>
        <p style="font-size:12px">${penjual}</p>
        <p>${desc}</p>
        <p><b>Rp ${Number(harga).toLocaleString()}</b></p>

        <a href="https://wa.me/${kontak}" target="_blank"
        style="display:block;background:#25D366;color:white;text-align:center;padding:5px;border-radius:8px">
        Chat
        </a>

      </div>`;
    });

    document.getElementById("listIklan").innerHTML = html || "Belum ada data";
  })
  .catch(err=>{
    console.log(err);
    document.getElementById("listIklan").innerHTML = "Error load data";
  });
}
function loadMedia(){

  fetch(URL_MEDIA)
  .then(res => res.text())
  .then(data => {

    let match = data.match(/google\.visualization\.Query\.setResponse\((.*)\);/s);

    if(!match){
      document.getElementById("gallery").innerHTML = "Data gagal dibaca";
      console.log("RAW:", data);
      return;
    }

    const json = JSON.parse(match[1]);
    const rows = json.table.rows;

    // 🔥 PARSE TANGGAL SUPER AMAN
    function parseTanggal(t){
      if(!t) return new Date(0);

      // format: Date(2026,3,20)
      if(typeof t === "string" && t.includes("Date(")){
        let m = t.match(/\d+/g);
        return new Date(m[0], m[1], m[2]);
      }

      // format: 2026-04-20
      if(typeof t === "string"){
        let p = t.split("-");
        if(p.length === 3){
          return new Date(p[0], p[1]-1, p[2]);
        }
      }

      // fallback
      return new Date(t);
    }

    // 🔥 SORT TERBARU DI ATAS
    rows.sort((a, b) => {
      return parseTanggal(b.c[3]?.v) - parseTanggal(a.c[3]?.v);
    });

    let html = "";

    rows.forEach((r,i) => {

      let kegiatan   = r.c[0]?.v || "";
      let link       = r.c[1]?.v || "";
      let keterangan = r.c[2]?.v || "";
      let tanggal    = r.c[3]?.v || "";

      let media = "";
      let url = convertDrive(link);

      // 🔥 GOOGLE DRIVE (VIDEO)
      if (link.includes("drive.google.com")) {

        let fileIdMatch = link.match(/\/d\/(.*?)\//);

        if (fileIdMatch) {
          let fileId = fileIdMatch[1];

          media = `
            <iframe 
              src="https://drive.google.com/file/d/${fileId}/preview"
              style="
                width:100%;
                height:150px;
                border:none;
                border-radius:10px;
                background:black;
              ">
            </iframe>
          `;
        }

      }

      // 🔥 VIDEO LANGSUNG
      else if (link.match(/\.(mp4|webm|ogg)$/i)) {

        media = `
          <video controls style="
            width:100%;
            height:150px;
            border-radius:10px;
            object-fit:cover;
            background:black;
          ">
            <source src="${link}" type="video/mp4">
          </video>
        `;
      }

      // 📷 GAMBAR
      else {

        media = `
          <img src="${url}" 
               style="
                 width:100%;
                 height:150px;
                 object-fit:contain;
                 background:white;
                 border-radius:10px;
               "
               onerror="this.src='https://via.placeholder.com/200x150?text=No+Image'">
        `;
      }

      // 🔥 FORMAT TANGGAL (ANTI INVALID)
      let tglFormat = "-";
      let d = parseTanggal(tanggal);

      if(!isNaN(d)){
        tglFormat = d.toLocaleDateString("id-ID", {
          day:"2-digit",
          month:"short",
          year:"numeric"
        });
      }

      // 🔥 CARD
      html += `
        <div style="
          width:200px;
          margin:10px;
          display:inline-block;
          vertical-align:top;
          background:white;
          border-radius:12px;
          padding:10px;
          box-shadow:0 5px 15px rgba(0,0,0,0.1);
        ">
          ${media}
          <b style="display:block;margin-top:8px">${kegiatan}</b>
          <p style="font-size:12px">${keterangan}</p>
          <p style="font-size:11px;color:#64748b">${tglFormat}</p>
        </div>
      `;
    });

    document.getElementById("gallery").innerHTML = html || "Tidak ada data";

  })
  .catch(err=>{
    console.log(err);
    document.getElementById("gallery").innerHTML = "Error load data";
  });

}
function loadPengumuman(){

  fetch(URL_PENGUMUMAN)
  .then(res => res.text())
  .then(data => {

    let match = data.match(/google\.visualization\.Query\.setResponse\(([\s\S]+)\);/);

    if(!match){
      document.getElementById("listPengumuman").innerHTML = "Data gagal dibaca";
      return;
    }

    let json = JSON.parse(match[1]);
    let rows = json.table.rows || [];

    let html = "";

    rows.forEach(r => {

      let judul = r.c[0]?.v || "";
      let isi   = r.c[1]?.v || "";
      let tanggal = r.c[2]?.v || "";
      let status = (r.c[8]?.v || "").toLowerCase();

      // hanya tampil yg aktif
      if(status && status !== "aktif") return;

      html += `
        <div class="card">
          <h3>${judul}</h3>
          <p>${isi}</p>
          <small>${tanggal}</small>
        </div>
      `;
    });

    document.getElementById("listPengumuman").innerHTML = html || "Tidak ada data";

  })
  .catch(()=>{
    document.getElementById("listPengumuman").innerHTML = "Error load data";
  });
}
function openTab(id){
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
  document.getElementById(id).classList.add("active");

  // 🔥 MEDIA FIX ANTI HITAM
  if(id === "Media"){
    setTimeout(()=>{
      loadMedia();
    }, 200); // kasih delay biar tab sudah render dulu
  }
  if(id === "pengumuman"){
      loadPengumuman();
    }
  if(id === "iklan"){
    loadIklan();
  }
}

function toggleMode(){
  document.body.classList.toggle("dark");
}
/* START */
load();
hujanDaun();

</script>

</body>
</html>
